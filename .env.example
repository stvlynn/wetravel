# Local shared env. Copy to `.env` with `make env`.

# Public origin used by the browser for API/auth calls. In dev this points at
# Vite, whose `/api` proxy forwards to the API on :8787.
BASE_URL=http://localhost:5173

# Postgres. Matches the docker compose defaults.
DATABASE_URL=postgres://wetravel:wetravel@localhost:5432/wetravel

# Better Auth. Secret must be >= 32 chars.
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef

# Origins allowed to call the API. Defaults to BASE_URL if omitted.
TRUSTED_ORIGINS=http://localhost:5173

# API port.
PORT=8787
