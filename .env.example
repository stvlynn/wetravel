# Local shared env. Copy to `.env` with `make env`.

# Public origin used by the browser for API/auth calls. In dev this points at
# Vite, whose `/api` proxy forwards to the API on :8780.
BASE_URL=http://localhost:5170

# SQL backend: postgres (default) | mysql.
# When omitted, inferred from DATABASE_URL scheme (mysql:// → mysql, else postgres).
DATABASE_PROVIDER=postgres

# Connection string. Postgres matches docker compose defaults on :5430.
# MySQL example: mysql://opentrip:opentrip@localhost:3306/opentrip
DATABASE_URL=postgres://opentrip:opentrip@localhost:5430/opentrip

# Better Auth. Secret must be >= 32 chars.
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
REALTIME_GRANT_SECRET=dev-realtime-secret-change-me-0123456789abcdef

# Origins allowed to call the API. Defaults to BASE_URL if omitted.
TRUSTED_ORIGINS=http://localhost:5170

# Optional: Google OAuth. Set both to enable "Sign in with Google".
# Redirect URI configured in Google Cloud Console must be:
#   {BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: WeChat web QR login (Open Platform Website Application).
# Callback domain/path: {BASE_URL}/api/auth/callback/wechat
WECHAT_WEB_APP_ID=
WECHAT_WEB_APP_SECRET=

# Optional: native Mini Program login (API server only).
# DevTools AppID lives in apps/miniapp/.env as TARO_APP_WECHAT_APP_ID and is
# synced by `make miniapp-sync-appid`. AppSecret must never ship to the client.
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=

# Transactional email for auth OTP (sign-up verification). Defaults to console
# logging so local OTP codes appear in the API process stdout.
# EMAIL_PROVIDER=console|resend
EMAIL_PROVIDER=console
EMAIL_FROM=OpenTrip <noreply@localhost>
# Required when EMAIL_PROVIDER=resend:
# RESEND_API_KEY=

# Captcha (Cloudflare Turnstile). Use test keys for local dev; replace with real
# keys in production. Comment out CAPTCHA_PROVIDER to disable captcha entirely.
CAPTCHA_PROVIDER=cloudflare-turnstile
CAPTCHA_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Avatar storage. Local development uses the filesystem; production can select
# `s3` and provide the S3-compatible variables documented in operations.
STORAGE_BACKEND=fs
STORAGE_ROOT=uploads

# API port.
PORT=8780

# Web dev server port.
WEB_PORT=5170

# OpenWeatherMap API key (used by the backend to proxy weather requests).
# Get a free key at https://openweathermap.org/api.
OPENWEATHERMAP_API_KEY=

# Unsplash access key for trip cover photos (create-trip wizard). Optional —
# without it, trip cards keep the decorative route SVG when no cover is set.
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# Geo provider for agent place/route tools. Defaults to OpenStreetMap
# (Nominatim + Overpass + OSRM). Set GEO_PROVIDER=google and provide
# GOOGLE_MAPS_API_KEY to use Google Places + Routes instead.
GEO_PROVIDER=osm
GEO_OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org
GEO_OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
GEO_OSM_OSRM_URL=https://router.project-osrm.org
# Identifying User-Agent required by public OSM usage policies.
GEO_OSM_USER_AGENT=OpenTrip/0.1 (https://github.com/stvlynn/OpenTrip; geo-agent)
# GEO_TIMEOUT_MS=12000
# GEO_CACHE_TTL_MS=1800000
GOOGLE_MAPS_API_KEY=

# Airbnb lodging tools for the trip agent (openbnb-style in-process scrape).
# No API key required. Respects Airbnb robots.txt by default.
# LODGING_IGNORE_ROBOTS_TXT=false
# LODGING_DISABLE_GEOCODING=false
# LODGING_TIMEOUT_MS=30000
# LODGING_GEOCODE_USER_AGENT=OpenTrip/0.1 (https://github.com/stvlynn/OpenTrip; lodging-geocode)

# Trip agent (Vercel AI SDK). The agent is disabled unless both AI_MODEL and
# AI_API_KEY are set.
# - openai: leave AI_BASE_URL empty for the OpenAI API, or set an OpenAI-compatible URL
# - minimax: AI_PROVIDER=minimax; leave AI_BASE_URL empty for Anthropic-compatible
#   https://api.minimaxi.com/anthropic/v1 (…/anthropic also accepted; /v1 is required
#   for @ai-sdk/anthropic so thinking streams as separate reasoning parts)
AI_PROVIDER=openai
AI_MODEL=
AI_BASE_URL=
AI_API_KEY=
# Minimum model confidence (0-1) before a proactive suggestion toast is created.
AI_PROACTIVE_THRESHOLD=0.7
# Upper bound on tool-call steps per chat generation.
AI_MAX_TOOL_STEPS=16
AI_TELEMETRY_RECORD_CONTENT=false

# Observability. Sentry is disabled when SENTRY_DSN is empty.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Operator-only historical Workers Logs query token. Do not sync to the Worker.
CLOUDFLARE_OBSERVABILITY_TOKEN=
# Platform-neutral street view. Unset provider to disable the capability.
STREET_VIEW_PROVIDER=
MAPILLARY_ACCESS_TOKEN=
# STREET_VIEW_TIMEOUT_MS=12000
