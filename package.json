{
    "name": "wetravel",
    "version": "0.1.0",
    "private": true,
    "description": "Travel Planner SaaS — plan trips together, split everything.",
    "packageManager": "pnpm@10.28.1",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "pnpm -r --parallel dev",
        "build": "pnpm -r build",
        "typecheck": "pnpm -r typecheck",
        "lint": "pnpm -r lint",
        "test": "pnpm -r test",
        "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm ui:check && pnpm build",
        "docs:check": "node scripts/docs-check.mjs",
        "ui:check": "node scripts/ui-check.mjs",
        "db:migrate": "pnpm --filter @wetravel/api db:migrate",
        "db:seed": "pnpm --filter @wetravel/api db:seed",
        "db:reset": "pnpm --filter @wetravel/api db:reset",
        "db:generate": "pnpm --filter @wetravel/api db:generate",
        "db:pull": "pnpm --filter @wetravel/api db:pull",
        "db:studio": "pnpm --filter @wetravel/api db:studio"
    },
    "devDependencies": {
        "typescript": "^5.7.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": ["@prisma/engines", "prisma", "esbuild"]
    }
}
