{
    "name": "opentrip",
    "version": "0.1.0",
    "private": true,
    "description": "Travel Planner SaaS — plan trips together, split everything.",
    "packageManager": "pnpm@10.28.1",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "pnpm --filter @opentrip/web --filter @opentrip/api --parallel dev",
        "build": "pnpm -r build",
        "typecheck": "pnpm -r typecheck",
        "lint": "pnpm -r lint",
        "test": "pnpm -r test",
        "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm ui:check && pnpm build",
        "docs:check": "node scripts/docs-check.mjs",
        "ui:check": "node scripts/ui-check.mjs",
        "db:migrate": "pnpm --filter @opentrip/api db:migrate",
        "db:seed": "pnpm --filter @opentrip/api db:seed",
        "db:reset": "pnpm --filter @opentrip/api db:reset",
        "db:generate": "pnpm --filter @opentrip/api db:generate",
        "db:pull": "pnpm --filter @opentrip/api db:pull",
        "db:studio": "pnpm --filter @opentrip/api db:studio",
        "dev:miniapp": "pnpm --filter @opentrip/miniapp dev",
        "build:miniapp": "pnpm --filter @opentrip/miniapp build",
        "deploy:web": "node deploy/cloudflare/scripts/deploy-web.mjs",
        "deploy:api": "node deploy/cloudflare/scripts/deploy-api.mjs",
        "deploy:secrets": "node deploy/cloudflare/scripts/sync-secrets.mjs",
        "logs:cf": "tsx --env-file-if-exists=.env scripts/cloudflare-logs.ts",
        "logs:cf:test": "vitest run scripts/cloudflare-logs.test.ts"
    },
    "devDependencies": {
        "@opentrip/observability-contract": "workspace:*",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vitest": "^2.1.8"
    },
    "pnpm": {
        "onlyBuiltDependencies": ["@prisma/engines", "prisma", "esbuild"]
    }
}
