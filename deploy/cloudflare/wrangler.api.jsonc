{
  // Cloudflare Workers config for the OpenTrip API (Hono).
  // Entry is the workspace worker file; wrangler bundles it with esbuild.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "opentrip-api",
  "main": "../../apps/api/src/worker.ts",
  "compatibility_date": "2025-01-01",
  // pg + Better Auth need Node built-ins on Workers.
  "compatibility_flags": ["nodejs_compat_v2"],
  "observability": {
    "enabled": true
  },
  // Hyperdrive fronts the external PostgreSQL. Replace `id` with the value from
  // `wrangler hyperdrive create opentrip-db --connection-string ...`.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "<your-hyperdrive-id>"
    }
  ],
  // Non-secret vars. BASE_URL is the public API Worker origin. Set
  // TRUSTED_ORIGINS to your Pages origin. Secrets go through `wrangler secret put`.
  "vars": {
    "BASE_URL": "https://opentrip-api.<your-subdomain>.workers.dev",
    "TRUSTED_ORIGINS": "https://opentrip-web.pages.dev",
    "STORAGE_BACKEND": "s3",
    "STORAGE_ROOT": "uploads",
    "S3_BUCKET": "opentrip-uploads",
    "S3_REGION": "auto",
    "S3_ENDPOINT": "https://<account-id>.r2.cloudflarestorage.com",
    "S3_FORCE_PATH_STYLE": "false",
    // Trip agent. Leave AI_MODEL empty (and skip the AI_API_KEY secret) to
    // disable the agent entirely.
    "AI_PROVIDER": "openai",
    "AI_MODEL": "",
    "AI_BASE_URL": "",
    "AI_PROACTIVE_THRESHOLD": "0.7",
    "AI_MAX_TOOL_STEPS": "5",
    // Geo agent tools. Default OSM; set google + GOOGLE_MAPS_API_KEY secret to switch.
    "GEO_PROVIDER": "osm",
    "GEO_OSM_USER_AGENT": "OpenTrip/0.1 (https://github.com/stvlynn/OpenTrip; geo-agent)"
  }
}
