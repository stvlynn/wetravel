# Copy to .env and fill in. Never commit the real .env.

# Postgres
POSTGRES_USER=opentrip
POSTGRES_PASSWORD=change-me
POSTGRES_DB=opentrip
POSTGRES_PORT=5430

# Better Auth — secret must be >= 32 chars (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=replace-with-a-32+-character-random-string
# Public origin the browser uses (nginx serves the SPA + proxies /api here).
BASE_URL=http://localhost:8090
WEB_ORIGIN=http://localhost:8090

# Optional: Google OAuth. Set both to enable "Sign in with Google".
# Redirect URI in Google Cloud Console must be: {BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WECHAT_WEB_APP_ID=
WECHAT_WEB_APP_SECRET=
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=

# Transactional email for auth OTP. Defaults to console (OTP in API logs).
EMAIL_PROVIDER=console
EMAIL_FROM=OpenTrip <noreply@localhost>
# RESEND_API_KEY=

# Persistent avatar storage mounted into the API container.
STORAGE_BACKEND=fs
STORAGE_ROOT=/app/apps/api/uploads
