<web-view
  wx:if="{{webviewUrl}}"
  src="{{webviewUrl}}"
  bindload="handleWebviewLoad"
  binderror="handleWebviewError"
/>

<view wx:else class="shell-state">
  <view wx:if="{{loading}}" class="shell-spinner" aria-label="正在连接 OpenTrip"></view>
  <block wx:else>
    <text class="shell-title">无法打开 OpenTrip</text>
    <text class="shell-message">{{errorMessage}}</text>
    <button class="shell-retry" bindtap="connect">重试</button>
  </block>
</view>
