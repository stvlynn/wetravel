# API origin the Mini Program calls directly (no Vite proxy).
# Local: http://localhost:8780 — enable "不校验合法域名" in WeChat DevTools.
# Production: https://api.opentrip.im (must be on the request-domain allowlist).
TARO_APP_API_BASE_URL=http://localhost:8780

# WeChat Mini Program AppID for Developer Tools (synced by make miniapp-sync-appid
# into gitignored project.private.config.json). Never commit a real AppID.
# AppSecret stays on the API only — root .env → WECHAT_MINI_PROGRAM_APP_SECRET.
TARO_APP_WECHAT_APP_ID=
